@code {
    private bool isDateTImeLocked = false; // Track the switch state
    private SfSwitch<bool> DateTImeLockSwitch; // Reference to the switch component

    private bool isDeviceInfoLocked = false; // Track the switch state
    private SfSwitch<bool> DeviceInfoLockSwitch;

    private bool isIpAddressLocked = false; // Track the switch state
    private SfSwitch<bool> IpAddressLockSwitch;

    string alertClass = "alert alert-danger";
    private string ErrorMessage { get; set; } = string.Empty;
    private string ipAddress { get; set; } = string.Empty;
    private string? ip { get; set; } = string.Empty;
    private UsersEntity userEntity = new();
    private UserAccessStatus? userAccessStatus = new();
    int userId;
    private string? deviceData;

    protected override async Task OnInitializedAsync()
    {
        isDateTImeLocked = false;
        isDeviceInfoLocked = false;
        isIpAddressLocked = false;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        userId = authState.User.GetUserId() ?? 0;
        userAccessStatus = await userDTO.GetUserAccessStatus(userId);

        if (userAccessStatus != null)
        {
            if (!string.IsNullOrEmpty(userAccessStatus.LockUpTo))
            {
                isDateTImeLocked = true;
            }
            if (!string.IsNullOrEmpty(userAccessStatus.DeviceId))
            {
                isDeviceInfoLocked = true;
            }
            if (!string.IsNullOrEmpty(userAccessStatus.IpAddress))
            {
                isIpAddressLocked = true;
                ipAddress = userAccessStatus.IpAddress;
                StateHasChanged();
            }
            else
            {
                isIpAddressLocked = true;

                //ip = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.ToString();
                if (string.IsNullOrEmpty(ip))
                {
                    ipAddress = "Unable to retrieve IP address.";
                }
                else
                {
                    ipAddress = ip ?? "";
                }
                StateHasChanged();
            }
        }
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                deviceData = userId.ToString() + await JS.InvokeAsync<string>("getDeviceInfo");

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
            }
        }
    }



    private async Task OnDateSwitchChange(Syncfusion.Blazor.Buttons.ChangeEventArgs<bool> args)
    {
        ErrorMessage = string.Empty;

        // VALIDATION: Check if the date is selected and in the future
        if (userEntity.LockUpTo == null || userEntity.LockUpTo <= DateTime.Now)
        {
            ErrorMessage = "Select a Date or Time Greater Than Current Date or Time";

            // CRITICAL: Force the switch back to OFF
            isDateTImeLocked = false;

            // Tell Blazor to re-render the UI immediately to show the switch moved back
            StateHasChanged();
            return;
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        userEntity.UserId = user.GetUserId() ?? 0;

        if (args.Checked)
        {
            await userDTO.UpdateLockUpTo(userEntity);

            ErrorMessage = "Account locked until " + userEntity.LockUpTo.ToString();
            alertClass = "alert alert-success";

            await Task.Delay(2000);
            ErrorMessage = string.Empty;
            StateHasChanged();
        }
        else
        {
            // Unlock logic
            await userDTO.UpdateLockUpTo(new UsersEntity
            {
                UserId = userEntity.UserId,
                LockUpTo = null
            });
            ErrorMessage = "Account unlocked.";
            alertClass = "alert alert-info";
        }
    }

    private async Task OnIpAddressSwitchChange(Syncfusion.Blazor.Buttons.ChangeEventArgs<bool> args)
    {
        ErrorMessage = string.Empty;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            // Extract the ID from claims (Ensure GetUserId() extension is working)
            userEntity.UserId = user.GetUserId() ?? 0;
            userEntity.UpdatedBy = userEntity.UserId;
        }
        if (userEntity.UserId == 0)
        {
            ErrorMessage = "User session not found. Please re-login.";
            return;
        }
        if (string.IsNullOrEmpty(ip))
        {
            isIpAddressLocked = false;
            ErrorMessage = "IP address cannot be empty.";
            return;
        }

        if (args.Checked)
        {
            try
            {
                await userDTO.DeviceIpAddress(ip, userEntity.UserId);
                ErrorMessage = "This Device has been locked up as your primary device with IP: " + ipAddress;
                alertClass = "alert alert-success";
            }
            catch (Exception ex)
            {
                ErrorMessage = "JS Error: " + ex.Message;
            }
        }
        else
        {
            await userDTO.DeviceIpAddress("NULL", userEntity.UserId);
            ErrorMessage = "This Device IP Address has been removed as your primary device.";
            alertClass = "alert alert-danger";
        }

    }

    private async Task OnDeviceInfoSwitchChange(Syncfusion.Blazor.Buttons.ChangeEventArgs<bool> args)
    {
        ErrorMessage = string.Empty;

        // 1. Get User Identity first
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        int currentUserId = user.GetUserId() ?? 0;

        if (currentUserId == 0)
        {
            isDeviceInfoLocked = false;
            ErrorMessage = "User session not found. Please re-login.";
            return;
        }

        // 2. Handle the "Locking" (Switch turned ON)
        if (args.Checked)
        {
            try
            {
                // Call JS to get the device string
                var deviceInfoRaw = await JS.InvokeAsync<string>("getDeviceInfo");

                if (string.IsNullOrEmpty(deviceInfoRaw))
                {
                    isDeviceInfoLocked = false;
                    ErrorMessage = "Device information could not be retrieved.";
                    return;
                }

                // Combine ID and Device Info
                deviceData = $"{currentUserId}{deviceInfoRaw}";

                // Save to Database
                await userDTO.DeviceInfo(deviceData, currentUserId);

                ErrorMessage = "This device is now locked as your Primary Device.";
                alertClass = "alert alert-success";
            }
            catch (Exception ex)
            {
                ErrorMessage = "JS Error: " + ex.Message;
            }
        }
        // 3. Handle the "Unlocking" (Switch turned OFF)
        else
        {
            deviceData = "NULL";
            await userDTO.DeviceInfo(deviceData, currentUserId);

            ErrorMessage = "This device has been removed as your primary device.";
            alertClass = "alert alert-danger";
        }

        StateHasChanged();
    }
}
