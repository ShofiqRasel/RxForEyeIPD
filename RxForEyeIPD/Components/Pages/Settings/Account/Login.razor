@page "/login"

@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using RxForEyeIPD.Components.Pages.Settings.Account.CsScript
@using static RxForEyeIPD.Components.Pages.Settings.LocationMaster.Users.srvUsers
@inject IUserAccountPolicy userAccountPolicy
@inject IUsers usersService
@inject NavigationManager navigationManager

<div class="row">
    <div class="col-lg-4 offset-lg-4 pt-4 border">
        <h3>Login</h3>
        <EditForm Model="usersEntity" OnValidSubmit="Authenticate" FormName="LoginForm">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <InputText id="username" class="form-control" @bind-Value="usersEntity.UserName" />
                <ValidationMessage For="@(() => usersEntity.UserName)" />
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="usersEntity.UserPassword" />
                <ValidationMessage For="@(() => usersEntity.UserPassword)" />
            </div>
            <div class="mb-3 text-center">
                <span class="text-danger">@ErrorMessage</span>
            </div>
            <button type="submit" class="btn btn-primary">Login</button>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter]
    public HttpContext HttpContext { get; set; } = default!;

    public string? ErrorMessage { get; set; }

    // [SupplyParameterFromForm]
    // public LoginViewModel LoginModel { get; set; } = new();

    public UsersEntity usersEntity = new();

    private async Task Authenticate()
    {
        // যদি কোন কিছু ইনপুট না দিয়েই লগইন করার চেষ্টা করা হয়, তাহলে একটি ত্রুটি বার্তা দেখানো হবে এবং প্রক্রিয়া বন্ধ হয়ে যাবে।
        if (string.IsNullOrWhiteSpace(usersEntity.UserName) || string.IsNullOrWhiteSpace(usersEntity.UserPassword))
        {
            ErrorMessage = "Username and password are required.";
            return;
        }

        // //যদি ইউজারনেম বা পাসওয়ার্ড ভুল হয়, তাহলে একটি ত্রুটি বার্তা দেখানো হবে এবং প্রক্রিয়া বন্ধ হয়ে যাবে।
        // //var userAccount = dbContext.UserAccounts.Where(u => u.UserName == LoginModel.UserName).FirstOrDefault();

        // var userAccount = await userAccountPolicy.GetUserDetail(LoginModel.UserName);

        // // Use the 'global::' prefix to bypass local namespace conflicts
        // bool isPasswordValid = userAccount != null && global::BCrypt.Net.BCrypt.Verify(LoginModel.Password, userAccount.UserPassword);

        // if (!isPasswordValid)
        // {
        //     ErrorMessage = "Invalid username or password.";
        //     return;
        // }



        // // এখানে ক্লেইম তৈরী করা হবে, যেখানে ইউজারনেম এবং ইউজার আইডি থাকবে। এছাড়াও ইউজারের পলিসি অনুযায়ী অতিরিক্ত ক্লেইম যোগ করা হবে।

        // var claims = new List<Claim>
        // {
        //     new Claim(ClaimTypes.Name, LoginModel.UserName),
        //     //new Claim(ClaimTypes.Role, userAccount.Role),
        //     //new Claim(ClaimTypes.NameIdentifier, userAccount.Id.ToString()) // 👈 USER ID
        // };


        // var userAccountPolicies = await userAccountPolicy.GetuserAccountPolicies(userAccount.UserId);

        // foreach (var policy in userAccountPolicies)
        // {
        //     claims.Add(new Claim(policy.AssingnUserPolicy, "true"));
        // }

        // var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);


        // var principal = new ClaimsPrincipal(identity);
        // await HttpContext.SignInAsync(principal);

        // navigationManager.NavigateTo("/", true);


        var userAccount = await usersService.AuthenticateUser(usersEntity.UserName, usersEntity.UserPassword);

        if (userAccount == null)
        {
            ErrorMessage = "Invalid username or password.";
            return;
        }

        var claims = new List<Claim>
        {
            new Claim(ClaimTypes.Name, userAccount.UserName),
            new Claim(ClaimTypes.NameIdentifier, userAccount.UserId.ToString())
        };

        var userPolicies = await userAccountPolicy.GetuserAccountPolicies(userAccount.UserId);

        foreach (var policy in userPolicies)
        {
            claims.Add(new Claim(policy.AssingnUserPolicy, "true"));
        }

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await HttpContext.SignInAsync(principal);

        navigationManager.NavigateTo("/", true);
    }
}