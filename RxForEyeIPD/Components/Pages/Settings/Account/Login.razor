@page "/login"

@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using RxForEyeIPD.Components.Pages.Settings.Account.CsScript
@inject clsAdoDotNetFroUser adoDotNetFroUser
@inject NavigationManager navigationManager

<div class="row">
    <div class="col-lg-4 offset-lg-4 pt-4 border">
        <h3>Login</h3>
        <EditForm Model="LoginModel" OnValidSubmit="Authenticate" FormName="LoginForm">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <InputText id="username" class="form-control" @bind-Value="LoginModel.UserName" />
                <ValidationMessage For="@(() => LoginModel.UserName)" />
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="LoginModel.Password" />
                <ValidationMessage For="@(() => LoginModel.Password)" />
            </div>
            <div class="mb-3 text-center">
                <span class="text-danger">@ErrorMessage</span>
            </div>
            <button type="submit" class="btn btn-primary">Login</button>
        </EditForm>
    </div>
</div>

@code {
    [CascadingParameter]
    public HttpContext HttpContext { get; set; } = default!;

    public string? ErrorMessage { get; set; }

    [SupplyParameterFromForm]
    public LoginViewModel LoginModel { get; set; } = new();

    private async Task Authenticate()
    {
        // যদি কোন কিছু ইনপুট না দিয়েই লগইন করার চেষ্টা করা হয়, তাহলে একটি ত্রুটি বার্তা দেখানো হবে এবং প্রক্রিয়া বন্ধ হয়ে যাবে।
        if (string.IsNullOrWhiteSpace(LoginModel.UserName) || string.IsNullOrWhiteSpace(LoginModel.Password))
        {
            ErrorMessage = "Username and password are required.";
            return;
        }

        //যদি ইউজারনেম বা পাসওয়ার্ড ভুল হয়, তাহলে একটি ত্রুটি বার্তা দেখানো হবে এবং প্রক্রিয়া বন্ধ হয়ে যাবে।
        //var userAccount = dbContext.UserAccounts.Where(u => u.UserName == LoginModel.UserName).FirstOrDefault();

        var userAccount = await adoDotNetFroUser.GetUserDetail(LoginModel.UserName);

        if (userAccount == null || userAccount.Password != LoginModel.Password)
        {
            ErrorMessage = "Invalid username or password.";
            return;
        }

        //এখানে ক্লেইম তৈরী করা হবে, যেখানে ইউজারনেম এবং ইউজার আইডি থাকবে। এছাড়াও ইউজারের পলিসি অনুযায়ী অতিরিক্ত ক্লেইম যোগ করা হবে।
        // তারপর এই ক্লেইমগুলো দিয়ে একটি ClaimsIdentity তৈরি করা হবে এবং সেটি দিয়ে একটি ClaimsPrincipal তৈরি করে সাইন ইন করা হবে।

        // var claims = new List<Claim>
        // {
        //     new Claim(ClaimTypes.Name, LoginModel.UserName)
        // };

        // var userAccountPolicies = dbContext.UserAccountPolicies
        //     .Where(p => p.UserAccountId == userAccount.Id && p.IsEnabled)
        //     .ToList();

        // foreach (var policy in userAccountPolicies)
        // {
        //     claims.Add(new Claim(policy.UserPolicy!, "true"));
        // }

        // var principal = new ClaimsPrincipal(identity);
        // await HttpContext.SignInAsync(principal);

        // var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);


        // এখানে ক্লেইম তৈরী করা হবে, যেখানে ইউজারনেম এবং ইউজার আইডি থাকবে। এছাড়াও ইউজারের পলিসি অনুযায়ী অতিরিক্ত ক্লেইম যোগ করা হবে।

        var claims = new List<Claim>
        {
            new Claim(ClaimTypes.Name, LoginModel.UserName),
            new Claim(ClaimTypes.Role, userAccount.Role),
            new Claim(ClaimTypes.NameIdentifier, userAccount.Id.ToString()) // 👈 USER ID
        };

        // add policy claims
        //var userAccountPolicies = dbContext.UserAccountPolicies.Where(p => p.UserAccountId == userAccount.Id && p.IsEnabled).ToList();

        var userAccountPolicies = await adoDotNetFroUser.GetuserAccountPolicies(userAccount.Id);

        foreach (var policy in userAccountPolicies)
        {
            claims.Add(new Claim(policy.UserPolicy!, "true"));
        }

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);


        var principal = new ClaimsPrincipal(identity);
        await HttpContext.SignInAsync(principal);

        navigationManager.NavigateTo("/", true);
    }
}