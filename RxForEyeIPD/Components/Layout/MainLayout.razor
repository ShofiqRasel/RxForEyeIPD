<div class="page">
     <div class="sidebar">
           <MenuBarFeatures />
    </div> 
 
    <main>
        <div class="main">
            <AuthorizeView>
                <Authorized>
                    <MenuBarFeatures />
                </Authorized>
                <NotAuthorized>
                    <div class="top-row px-4">
                        <a href="/login">Login</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>