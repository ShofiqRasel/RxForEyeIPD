@using RxForEyeIPD.Components.Pages.DynamicFileCreator.Users.CsScript
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <AuthorizeView>
            <Authorized>
                <MenuBarFeatures />
            </Authorized>
        </AuthorizeView>
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView Context="authUser">
                <Authorized>
                    <span>Hello, @authUser.User.Identity?.Name!</span>

                    <!-- Nested AuthorizeView with DIFFERENT context -->
                    <AuthorizeView Roles="Admin,Super Admin" Context="adminUser">
                        <Authorized>
                            <button class="btn btn-warning">Admin Panel</button>
                        </Authorized>
                    </AuthorizeView>

                    <AuthorizeView Roles="Doctor" Context="docUser">
                        <Authorized>
                            <button class="btn btn-info">Doctor Dashboard</button>
                        </Authorized>
                    </AuthorizeView>

                    <a href="/logout">Logout</a>
                </Authorized>

                <NotAuthorized>
                    <a href="/login">Login</a>
                </NotAuthorized>
            </AuthorizeView>

        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
