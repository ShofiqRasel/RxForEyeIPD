@page "/menubar-features"
@using Microsoft.AspNetCore.Components.Authorization
@using Syncfusion.Blazor.Buttons
@using Syncfusion.Blazor.Navigations
@using Syncfusion.Blazor.SplitButtons
@using System.Security.Claims
@rendermode InteractiveServer


<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container-fluid">
        <!-- Brand -->
        <a class="navbar-brand" href="#">IPD Management System</a>

        <!-- Toggler for mobile -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navbar links - all right aligned -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                <!-- ms-auto pushes everything to the right -->
                <AuthorizeView Policy="@UserPolicy.VIEW_PRODUCT">
                    <Authorized>
                        <!-- Patient -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#">
                                <i class="e-icons e-people"></i> Patient
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <!-- Submenu -->
                                <li class="dropdown-submenu">
                                    <a class="dropdown-item dropdown-toggle" href="#">
                                        <span class="material-symbols-outlined">patient_list</span> Op Management
                                    </a>

                                    <ul class="dropdown-menu">
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"> <i class="e-icons e-edit"></i> New Registration </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"> <i class="fa-solid fa-cash-register"></i> Billing </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/visual-acuity"> <i class="fa-solid fa-magnifying-glass-plus"></i> VA & Refraction </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/historyandcomplaints"> <i class="fa fa-history"></i> History & Comp. </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/dynamicparentcomponent"> <i class="fa fa-history"></i> Dynamic Component </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/doctorexam"> <i class="fas fa-user-md"></i> Doctor Exam </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/counselling"> <i class="fas fa-hands-helping"></i> Counselling </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/medicineprescription"> <i class="fa-solid fa-prescription"></i> Medicine Prescription </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/medicineprescriptionwithdeleteupdate"> <i class="fa-solid fa-prescription"></i> Prescription With Edit Delete</a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"> <i class="fa-regular fa-folder-closed"></i> Medical Record </a> </li>
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="/smooth-scroll"> <i class="fa-regular fa-folder-closed"></i> Smooth Scroll </a> </li>
                                    </ul>
                                </li>

                                <!-- Submenu -->
                                <li class="dropdown-submenu">
                                    <a class="dropdown-item dropdown-toggle" href="#">
                                        <span class="material-symbols-outlined">assignment_add</span> Reports
                                    </a>

                                    <ul class="dropdown-menu">
                                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"> <i class="fa-solid fa-search"></i> Cencus </a> </li>
                                    </ul>
                                </li>
                            </ul>
                        </li>
                    </Authorized>
                </AuthorizeView>
                <!-- Outreach -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#">
                        <i class="e-icons e-objects"></i> Outreach
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"><span class="material-symbols-outlined">outpatient</span> RREC </a> </li>
                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"><span class="material-symbols-outlined">outpatient_med</span> SSTP </a> </li>
                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"><span class="material-symbols-outlined">patient_list</span> PTTP </a> </li>
                        <li> <a class="dropdown-item text-decoration-none p-2" href="#"><span class="material-symbols-outlined">clinical_notes</span> VDTP </a> </li>
                    </ul>
                </li>


                <!-- User Account -->

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#">
                        <i class="e-icons e-user"></i><span> User</span>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end">
                        <li> <a class="dropdown-item text-decoration-none p-2" href="/basehospitallist"><span class="material-symbols-outlined">moving_ministry</span> Base Master </a> </li> @* bi for bootstrap *@
                        <li> <a class="dropdown-item text-decoration-none p-2" href="/branchunitlist"><span class="material-symbols-outlined">home_health</span> Branch Master </a> </li>
                        <li> <a class="dropdown-item text-decoration-none p-2" href="/userrolelist"><span class="material-symbols-outlined">person_add</span> User Role </a> </li>@*  e-icons for syncfusion *@
                        <li> <a class="dropdown-item text-decoration-none p-2" href="/userlist"><span class="material-symbols-outlined">person_add</span> User Master </a> </li>@*  e-icons for syncfusion *@

                    </ul>
                </li>







            </ul>
        </div>
    </div>
</nav>


